      "preRunCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/attach-pre-run.lldb"
      ]
    },
    {
      "name": "Sucre Snort: Run (real device)",
      "type": "lldb",
      "request": "launch",
      "initCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/run-init.lldb"
      ],
      "targetCreateCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/run-target-create.lldb"
      ],
      "processCreateCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/run-process-create.lldb"
      ],
      "preLaunchTask": "snort-debug-run-workflow",
      "postDebugTask": "snort-debug-cleanup",
      "preRunCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/run-pre-run.lldb"
      ]
    }
  ]
