{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sucre Snort: Attach (real device)",
      "type": "lldb",
      "request": "launch",
      "initCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/attach-init.lldb"
      ],
      "targetCreateCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/attach-target-create.lldb"
      ],
      "processCreateCommands": [
        "command source ${workspaceFolder}/build-output/vscode-debug/attach-process-create.lldb"
      ],
      "preLaunchTask": "snort-debug-attach-workflow",
